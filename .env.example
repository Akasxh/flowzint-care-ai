# FlowZint Care AI — OpenAI-only MVP
# Copy to .env in repo root, or pass via scripts/start.sh
#
# REQUIRED for chat + document RAG with OpenAI:
#   - One OpenAI API key (https://platform.openai.com/api-keys)
#   - Server reads OPEN_AI_KEY (start.sh maps OPENAI_API_KEY → OPEN_AI_KEY)
#
# NOT required for basic Returns Desk demo:
#   - Groq, Anthropic, Gemini, vector DB cloud keys, agent search APIs, TTS keys
#   - Embeddings default to native (local) unless you set EMBEDDING_ENGINE=openai

SERVER_PORT=3001
STORAGE_DIR="/app/server/storage"

# --- OpenAI (required for MVP) ---
LLM_PROVIDER=openai
OPEN_AI_KEY=
OPENAI_API_KEY=
OPEN_MODEL_PREF=gpt-4o-mini

# --- Admin API key (optional — auto-generated by setup-workspace.sh) ---
# Save locally after first run; NEVER commit real values
# FLOWZINT_API_KEY=

# Optional: use OpenAI for embeddings too (same key as above)
# EMBEDDING_ENGINE=openai
# EMBEDDING_MODEL_PREF=text-embedding-3-small

# Default vector store (no extra signup)
VECTOR_DB=lancedb
EMBEDDING_ENGINE=native
EMBEDDING_MODEL_PREF=Xenova/all-MiniLM-L6-v2
